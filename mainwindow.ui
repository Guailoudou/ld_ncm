  <property name="styleSheet">
   <string notr="true">
/* 主窗口样式 */
QMainWindow {
    background-color: #f5f5f5;
}

/* 搜索框 */
QLineEdit {
    border: 2px solid #e0e0e0;
    border-radius: 20px;
    padding: 10px 20px;
    background-color: #ffffff;
    font-size: 14px;
    selection-background-color: #C20C0C;
}
QLineEdit:focus {
    border: 2px solid #C20C0C;
}

/* 按钮样式 */
QPushButton {
    border: none;
    border-radius: 20px;
    padding: 10px 24px;
    background-color: #C20C0C;
    color: white;
    font-size: 14px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #a80a0a;
}
QPushButton:pressed {
    background-color: #8a0808;
}

/* 列表样式 */
QListWidget {
    border: none;
    border-radius: 12px;
    background-color: #ffffff;
    padding: 10px;
    font-size: 14px;
}
QListWidget::item {
    border-radius: 8px;
    padding: 8px;
}
QListWidget::item:selected {
    background-color: #f0e8e8;
}
QListWidget::item:hover {
    background-color: #faf0f0;
}

/* 进度条样式 */
QSlider::horizontal {
    padding: 0 5px;
}
QSlider::groove:horizontal {
    border: none;
    background: #e0e0e0;
    border-radius: 3px;
    height: 6px;
    margin: 0 0px;
}
QSlider::handle:horizontal {
    width: 20px;
    height: 20px;
    margin: -7px 0;
    background: qradialgradient(cx:0.35, cy:0.35, radius:0.7, fx:0.35, fy:0.35, stop:0 #ff6b6b, stop:0.5 #C20C0C, stop:1 #a80a0a);
    border-radius: 10px;
}
QSlider::handle:horizontal:hover {
    background: qradialgradient(cx:0.35, cy:0.35, radius:0.7, fx:0.35, fy:0.35, stop:0 #ff8a8a, stop:0.5 #a80a0a, stop:1 #8a0808);
}
QSlider::sub-page:horizontal {
    background: #C20C0C;
    border-radius: 3px;
}

/* 歌词标签 */
QLabel {
    color: #333333;
    font-size: 14px;
}

/* 菜单栏 */
QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e0e0e0;
}
QMenuBar::item {
    padding: 8px 16px;
    color: #333333;
}

/* 滚动条 */
QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 8px;
}
QScrollBar::handle:vertical {
    background: #c0c0c0;
    border-radius: 4px;
}
QScrollBar::handle:vertical:hover {
    background: #a0a0a0;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: transparent;
    height: 0px;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: transparent;
}
   </string>
